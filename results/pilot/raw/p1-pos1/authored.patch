@@ -323,6 +323,54 @@ describe('transaction', () => {
             })
         })
 
+        // Appended headers must land in the header section of the serialized
+        // message, not after the body. See haraka/Haraka#2986.
+        const appends_to_header_section = (desc, lines, expect_body) => {
+            it(desc, (done) => {
+                for (const line of lines) this.transaction.add_data(Buffer.from(line))
+                this.transaction.end_data(() => {
+                    this.transaction.add_header('X-Spam-Level', '***')
+                    this.transaction.message_stream.get_data((data) => {
+                        const msg = data.toString()
+                        const sep = msg.indexOf('\r\n\r\n')
+                        assert.ok(sep !== -1, 'message has a header/body separator')
+                        const headers = msg.slice(0, sep + 2)
+                        const body = msg.slice(sep + 4)
+                        const where = `appended header is in the header section: ${JSON.stringify(msg)}`
+                        assert.ok(headers.includes('X-Spam-Level: ***\r\n'), where)
+                        assert.equal(body, expect_body)
+                        done()
+                    })
+                })
+            })
+        }
+
+        appends_to_header_section('normal message', ['Subject: original\r\n', '\r\n', 'body\r\n'], 'body\r\n')
+
+        // DATA opens with the separator: the message has no headers of its own.
+        // Previously header_pos stayed 0, so the body was re-parsed as headers.
+        appends_to_header_section(
+            'message with an empty header block',
+            ['\r\n', 'Hello world\r\n', '\r\n', 'More body\r\n'],
+            'Hello world\r\n\r\nMore body\r\n',
+        )
+
+        // No blank line between headers and body.
+        appends_to_header_section(
+            'message with no header/body separator',
+            ['Subject: original\r\n', 'Hello world\r\n', 'More body\r\n'],
+            'Hello world\r\nMore body\r\n',
+        )
+
+        // Nothing that looks like a header at all.
+        appends_to_header_section(
+            'message that is all body',
+            ['Hello world\r\n', 'More body\r\n'],
+            'Hello world\r\nMore body\r\n',
+        )
+
+        appends_to_header_section('message that is all headers', ['Subject: original\r\n'], '')
+
         it('remove_header removes a header', (done) => {
             this.transaction.add_data('X-Remove: gone\n')
             this.transaction.add_data('\n')
