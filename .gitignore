# secrets / keys — committed BEFORE any key-bearing file can exist (D-019).
# The judge key lives in the shell environment only (CVRE_GEMINI_JUDGE_KEY);
# no file below should ever be needed, these patterns are the backstop.
.env
.env.*
!.env.example
*.key
*.pem
*_key*
*apikey*
*api-key*
credentials*
secrets*
service-account*.json

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# os / editor
.DS_Store
.idea/
.vscode/

# run artifacts (kept out of git until we decide what to publish)
data/cache/
results/runs/
*.log

# generated doc exports (regenerate via tools/render-doc.sh)
exports/
